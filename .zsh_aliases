# System and Package Management (pacman)
alias update="sudo pacman -Syu"                   # Update package database and upgrade system
alias install="sudo pacman -S"                    # Install a package
alias remove="sudo pacman -Rns"                   # Remove a package and its dependencies
alias search="pacman -Ss"                         # Search for a package in repos
alias localsearch="pacman -Qs"                    # List all installed packages
alias pkginfo="pacman -Qi"                        # Show detailed package info
alias orphaned="sudo pacman -Rns $(pacman -Qtdq)" # Remove orphaned packages
alias clean="sudo pacman -Sc"                     # Clean cached packages

# File Navigation and Operations
alias ls="ls -alhF --color=auto"             # List with color
alias cp="cp -iv"                            # Prompt before overwrite
alias mv="mv -iv"                            # Prompt before overwrite
alias rm="rm -i"                             # Prompt before delete
alias mkdir="mkdir -pv"                      # Create directories with verbose output
alias df="df -h"                             # Disk usage with human-readable sizes
alias du="du -h --max-depth=1"               # Folder sizes in the current directory
alias ps="ps -ef"                            # Show all running processes

# Git Aliases
#alias gst="git status"                       # Git status
#alias gadd="git add"                         # Add files to staging
#alias gcom="git commit -m"                   # Commit with a message
#alias gpsh="git push"                        # Push changes
